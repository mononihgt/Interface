# Copy this file to /etc/interface-v2/interface-v2.env and fill in secrets.
# Stable limits, timeouts, cookie names, and experiment policy use tested code defaults.

APP_BASE_URL=https://your.domain.example
APP_SECRET_KEY=
DATA_DIR=/var/lib/interface-v2
DATABASE_URL=sqlite:////var/lib/interface-v2/app.db

ADMIN_USER=admin
# Generate an encoded Argon2id hash without putting the password in shell history:
# uv run python -c 'from getpass import getpass; from argon2 import PasswordHasher; print(PasswordHasher().hash(getpass("Admin password: ")))'
ADMIN_PASSWORD_HASH=
# Legacy SHA-256 migration only; uncomment until one successful login upgrades the verifier.
# ADMIN_PASSWORD_SALT=

YIZHAN_BASE_URL=https://vip.yi-zhan.top/v1
YIZHAN_API_KEY=
AABAO_BASE_URL=https://api.aabao.ai/v1
AABAO_API_KEY=
PACKYAPI_BASE_URL=https://www.packyapi.com/v1
PACKYAPI_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

MAIN_MODEL_PRIMARY=gpt-5.1
MAIN_MODEL_FALLBACK=gpt-5

TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_ASR_ENDPOINT=asr.ap-hongkong.tencentcloudapi.com
